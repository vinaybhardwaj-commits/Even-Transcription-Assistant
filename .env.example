# =============================================================================
# Even Transcription Assistant — env vars
# =============================================================================
# Canonical list. Copy to .env.local for local dev (NEVER commit).
# Production values live in Vercel env (Sensitive type).
# See ETA-BUILD-PLAN.md §2 for full descriptions.
# =============================================================================

# --- Mac Mini tunnels (existing infra; reuse from OPD/CDMSS) ---
OLLAMA_BASE_URL=https://llm.llmvinayminihome.uk/v1
WHISPER_BASE_URL=https://whisper.llmvinayminihome.uk
DEEPGRAM_API_KEY=

# --- Databases ---
# APP_DATABASE — new Neon project, provisioned in Sprint 0
APP_DATABASE_URL=
APP_DATABASE_URL_UNPOOLED=
# KB_DATABASE — existing Neon DB shared with OPD + CDMSS (read-only)
KB_DATABASE_URL=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=transcripts@eta.even.in
RESEND_WEBHOOK_SECRET=

# --- Audio storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=eta-audio

# --- Auth secrets (generated; never committed) ---
# Two audiences per PRD §4.15
JWT_SECRET_DOCTOR=
JWT_SECRET_ADMIN=

# --- Admin gate (PRD §4.16) ---
# 32-char URL-safe random — obscured admin URL prefix
ADMIN_BASE_PATH=
# Bearer token for admin API routes
ADMIN_TOKEN=

# --- Migration runner ---
MIGRATION_SECRET=

# --- Misc ---
APP_URL=https://eta.even.in
NODE_ENV=development
