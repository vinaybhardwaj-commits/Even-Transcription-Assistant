# =============================================================================
# Even Transcription Assistant (Evenscribe) — environment variables
# =============================================================================
# Copy to .env.local for local dev (NEVER commit real values).
# Production values live in Vercel env (Sensitive type), region bom1.
# This file lists EVERY variable the code reads (grep process.env). Values shown
# are placeholders/defaults only.
# =============================================================================

# --- Databases (Neon Postgres, accessed via the serverless HTTP driver) -------
# APP DB — encounters/clinicians/notes/sends/traces/voiceprints/STT-lab.
DATABASE_URL=
APP_DATABASE_URL=
APP_DATABASE_URL_UNPOOLED=
# KB DB — read-only pgvector knowledge base (shared with sibling apps).
KB_DATABASE_URL=

# --- Auth (jose JWT HS256; two audiences) ------------------------------------
JWT_SECRET_DOCTOR=          # signs doctor PIN sessions (cookie rounds_session)
JWT_SECRET_ADMIN=           # signs admin sessions (cookie eta_admin_session, Path=/)

# --- Admin gate ---------------------------------------------------------------
ADMIN_BASE_PATH=            # 32-char URL-safe random; obscured admin URL prefix
ADMIN_TOKEN=                # bearer for privileged admin bootstrap routes
ADMIN_PASSWORD_CURRENT=     # shared admin password (migrate to per-admin creds)

# --- Migration runner + cron --------------------------------------------------
MIGRATION_SECRET=           # bearer for POST /api/run-migrations and reap-stuck
CRON_SECRET=                # optional; defense-in-depth for the Vercel cron (x-vercel-cron is the primary auth)

# --- LLM (self-hosted Ollama, OpenAI-compatible; Mac-Mini tunnel) -------------
OLLAMA_BASE_URL=            # e.g. https://<tunnel>/v1  (NOTE: include /v1)
LLM_BASE_URL=               # optional override; falls back to OLLAMA_BASE_URL
LLM_API_KEY=                # optional; "ollama" if unset
# Per-stage model overrides (all optional; sensible defaults in code):
NOTE_MODEL=                 # note generation (default qwen2.5:14b)
CDS_MODEL=
CDS_DRAFT_MODEL=
CDS_CRITIQUE_MODEL=
CDS_REVISE_MODEL=
HYDE_MODEL=
CLEANUP_MODEL=
TEXT_MODEL=
EMBED_MODEL=                # embeddings for KB retrieval (default nomic-embed-text)
TOP_K=                      # KB retrieval depth

# --- Transcription / ASR ------------------------------------------------------
DEEPGRAM_API_KEY=           # live English WebSocket transcription
DEEPGRAM_PROJECT_ID=
WHISPER_BASE_URL=           # Mac-Mini Whisper ASR (rolling medical-term accuracy)
INDICCONFORMER_BASE_URL=    # AI4Bharat IndicConformer Indic ASR (Mac-Mini Pattern B; e.g. https://indic.llmvinayminihome.uk)
INDICCONFORMER_DECODING=    # rnnt (default, accurate) | ctc (faster)
ETA_NOTE_PARALLEL_INDIC=    # 1 = submit-time pick-best (Sarvam vs IndicConformer) for the Indic note; OFF by default
ETA_INDIC_COMPREHENSION=    # Indic comprehension layer: save native-language analysis + feed native transcript as note reference. ON by default; set 0 to disable.
SARVAM_API_KEY=             # Sarvam Saaras v3 (Indic transcribe + translate)
SARVAM_STT_MODEL=           # default saaras:v3
NEXT_PUBLIC_STT_RELAY_URL=  # wss://... Mac-Mini Sarvam streaming relay (client-visible)
STT_RELAY_URL=              # server-side relay URL (if used)
STT_RELAY_SECRET=           # HMAC token minted for the relay

# --- STT Engine Lab competitors ----------------------------------------------
ELEVENLABS_API_KEY=         # ElevenLabs Scribe v2 (ASR + showcased scribe engine)
ELEVENLABS_STT_MODEL=       # default scribe_v2
EKACARE_CLIENT_ID=          # eka.care OAuth client-credentials (engine DISABLED via migration 0026)
EKACARE_CLIENT_SECRET=
EKASCRIBE_MODEL=
EKASCRIBE_SCRIBE_TEMPLATE=
EKASCRIBE_SCRIBE_COMPANION_TEMPLATE=
STT_GOLD_EXTRACT_MODEL=     # medical-term extraction for gold WER scoring
OPENAI_API_KEY=             # optional; cloud term extraction (unset = use local qwen)

# --- Speaker diarization / voiceprint (Mac-Mini pyannote) ---------------------
DIARIZE_BASE_URL=           # https://... pyannote diarize + enroll service
DIARIZE_TIMEOUT_MS=         # e.g. 90000
PASSIVE_VOICEPRINT_GATE=    # confidence to auto-retain a passive voice sample (e.g. 0.82)

# --- Audio storage (Cloudflare R2, S3-compatible) -----------------------------
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=                  # e.g. eta-audio
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ADMIN_ACCESS_KEY_ID=     # separate key for admin audio download/CORS-fix
R2_ADMIN_SECRET_ACCESS_KEY=

# --- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=      # svix signing secret for delivery webhooks

# --- Live-path feature flags (client; default OFF = byte-identical prod) -------
NEXT_PUBLIC_ETA_TRIM_LIVE_BUFFERS=     # trim consumed live-transcription chunks
NEXT_PUBLIC_ETA_DEEPGRAM_RECONNECT=    # Deepgram live WS reconnect + token re-mint
NEXT_PUBLIC_ETA_SAFARI_STREAMING_GUARD=# extend the iOS worklet-skip to desktop Safari
NEXT_PUBLIC_ETA_INDIC_LIVE_BOX=        # ON by default (auto on non-English encounters). Set to 0 to kill-switch the 2nd native-script box.

# --- App ----------------------------------------------------------------------
APP_URL=                    # canonical app URL (https://www.evenscribe.app)

# --- Test/CI only (not needed at runtime) ------------------------------------
BASE_URL=                   # smoke.mjs target (default https://www.evenscribe.app)
EXPECT_SHA=                 # smoke: assert live build sha
SMOKE_DOCTOR_SLUG=          # smoke: assert a doctor PIN page renders
SMOKE_ADMIN_EMAIL=          # smoke: assert STT-lab engine health
SMOKE_ADMIN_PASSWORD=
PLAYWRIGHT_DOCTOR_SLUG=     # e2e
PLAYWRIGHT_DOCTOR_PIN=      # e2e (GitHub secret E2E_DOCTOR_PIN)
